CHANNEL_LAGERRUMMET=C0123456789
CHANNEL_METALLRUMMET=C0123456789
CHANNEL_SILVERSMIDESRUMMET=C0123456789
CHANNEL_STORA_RUMMET=C0123456789
CHANNEL_SVETSRUMMET=C0123456789
CHANNEL_TEXTILRUMMET=C0123456789
